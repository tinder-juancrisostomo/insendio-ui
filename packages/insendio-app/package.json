{
  "name": "@design-system/insendio-app",
  "version": "1.0.0",
  "description": "Shared Insendio app structure, mock data, and page components",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "sideEffects": false,
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.tsx --format cjs,esm --dts --external react --external react-router-dom",
    "lint": "eslint src/"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-router-dom": ">=6.0.0"
  },
  "dependencies": {
    "@design-system/base": "workspace:*",
    "@design-system/icons": "workspace:*",
    "@design-system/typography": "workspace:*",
    "@design-system/utils": "workspace:*"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "react": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3"
  }
}
