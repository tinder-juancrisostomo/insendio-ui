{
  "name": "@design-system/charts",
  "version": "1.0.0",
  "description": "Chart components styled with design tokens - Bar, Line, Pie, Area, Network",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "development": "./src/index.tsx",
