{
  "name": "@design-system/daisyui",
  "version": "1.0.0",
  "description": "Design system components styled with DaisyUI",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.tsx --format cjs,esm --dts --external react",
    "lint": "eslint src/"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "daisyui": ">=4.0.0"
  },
  "dependencies": {
    "@design-system/base": "workspace:*",
    "@design-system/utils": "workspace:*",
    "react-daisyui": "^5.0.5"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "daisyui": "^4.12.14",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.15",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3"
  }
}
